<!DOCTYPE html<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Horário - ESTGA</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <!-- Cabeçalho -->
        <div class="header">
            <h1 id="roomTitle">📍 Sala</h1>
            <p>Horário da semana</p>
        </div>

        <!-- Navegação -->
        <div class="week-navigation">
            <button id="prevWeek" aria-label="Semana anterior">← Semana</button>
            <span class="week-label" id="weekLabel">Carregando...</span>
            <button id="nextWeek" aria-label="Próxima semana">Semana →</button>
        </div>

        <!-- Dias da semana -->
        <div class="days-grid" id="daysContainer">
            <div class="loading">⏳ A carregar horário...</div>
        </div>

        <!-- Botão voltar -->
        <button id="backButton" class="back-button">← Voltar às salas</button>
    </div>

    <script src="main.js"></script>
</body>
</html>